package basics;

public class demo2 {
public static void main(String[] args) {
	int a=10;
	int b=20;
	int c=30;
	largestOfNum(a,b,c);
}
static int largestOfNum(int a,int b,int c) {
	if(a>b&&a>c) {
		System.out.println(a);
	}
	else if(b>c&&b>a) {
		System.out.println(b);
	}
	else if(c>a&&c>b) {
		System.out.println(c);
	}
}
}
