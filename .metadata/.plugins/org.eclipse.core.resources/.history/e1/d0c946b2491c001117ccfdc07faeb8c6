package basics;

public class Demo1 {
public static void main(String[] args) {
	int age=20;
	System.out.println(age);
	System.out.println("hello");
	boolean result=oddeven(age);
	System.out.println(result);
	stars();
	starpattern();
	
}
static boolean oddeven(int num) {
	return num%2==0;
}
static void stars() {
for(int i=0;i<5;i++) {
	System.out.println("*");
}
}
static void starpattern() {
	for(int i=0;i<5;i++) {
		for(int j=5;j>=i;j--) {
			System.out.print("*");
		}
		System.out.println();
	}
}
}
